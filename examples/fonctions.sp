@langue fr

— Exemple 4 : Les fonctions
faire saluer avec prénom
  donner "Bonjour " + prénom + " !"
fin

faire additionner avec a, b
  donner a + b
fin

faire séparateur
  afficher "────────────────────────"
fin

séparateur()
afficher saluer("Luther")
afficher "15 + 27 = " + additionner(15, 27)
séparateur()
